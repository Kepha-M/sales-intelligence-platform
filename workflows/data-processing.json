{
  "name": "Car Sales Automation",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const data = items.map(i => i.json);\n\nlet revenueByCountry = {};\nlet carSales = {};\nlet segmentStats = {};\nlet revenueByCity = {};\n\ndata.forEach(d => {\n  const revenue = Number(d.TotalPrice);\n  const qty = Number(d.Quantity);\n  const profit = Number(d[\"Total Profit\"]);\n\n  // Revenue by country\n  revenueByCountry[d.Country] = (revenueByCountry[d.Country] || 0) + revenue;\n\n  // Top cars\n  const car = `${d.Brand} ${d.Model}`;\n  carSales[car] = (carSales[car] || 0) + qty;\n\n  // Segment\n  if (!segmentStats[d.Segment]) {\n    segmentStats[d.Segment] = { sales: 0, profit: 0 };\n  }\n  segmentStats[d.Segment].sales += qty;\n  segmentStats[d.Segment].profit += profit;\n\n  // City revenue\n  revenueByCity[d.City] = (revenueByCity[d.City] || 0) + revenue;\n});\n\n// Top 3 cars\nconst topCars = Object.entries(carSales)\n  .sort((a,b) => b[1] - a[1])\n  .slice(0,3);\n\nreturn [{\n  json: {\n    revenueByCountry,\n    topCars,\n    segmentStats,\n    revenueByCity\n  }\n}];"
      },
