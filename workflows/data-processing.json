    {
      "parameters": {
        "jsCode": "const sales = $items(\"Get Sales\").map(i => i.json);\nconst dealers = $items(\"Get Dealers\").map(i => i.json);\nconst models = $items(\"Get Models\").map(i => i.json);\n\n// Create lookup maps\nconst dealerMap = {};\ndealers.forEach(d => dealerMap[d.DealerID] = d);\n\nconst modelMap = {};\nmodels.forEach(m => modelMap[m.ModelID] = m);\n\n// Join all\nconst result = sales.map(s => {\n  const dealer = dealerMap[s.DealerID] || {};\n  const model = modelMap[s.ModelID] || {};\n\n  return {\n    ...s,\n    City: dealer.City,\n    Country: dealer.Country,\n    Segment: model.Segment,\n    Brand: model.Brand,\n    Model: model.Model\n  };\n});\n\nreturn result.map(r => ({ json: r }));"
      },
